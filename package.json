{
  "name": "p2p-hiverelay",
  "version": "0.1.0",
  "description": "Shared P2P relay backbone for the Holepunch/Pear ecosystem",
  "type": "module",
  "main": "core/index.js",
  "exports": {
    ".": "./core/index.js",
    "./client": "./client/index.js",
    "./gateway": "./compute/gateway/hyper-gateway.js"
  },
  "bin": {
    "p2p-hiverelay": "./cli/index.js",
    "hiverelay": "./cli/index.js"
  },
  "files": [
    "cli/",
    "client/",
    "core/",
    "compute/",
    "config/",
    "incentive/",
    "transports/",
    "dashboard/",
    "scripts/publish-app.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node cli/index.js start",
    "test": "brittle test/**/*.test.js",
    "test:unit": "brittle test/unit/**/*.test.js",
    "test:integration": "brittle test/integration/**/*.test.js",
    "lint": "standard",
    "lint:fix": "standard --fix"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.7.15",
    "autobase": "^6.0.0",
    "b4a": "^1.6.6",
    "compact-encoding": "^2.15.0",
    "corestore": "^6.18.0",
    "graceful-goodbye": "^1.3.0",
    "holesail-client": "^2.3.0",
    "holesail-server": "^2.4.0",
    "hypercore": "^10.36.0",
    "hyperdht": "^6.15.0",
    "hyperdrive": "^11.8.0",
    "hyperswarm": "^4.7.0",
    "minimist": "^1.2.8",
    "multicast-dns": "^7.2.5",
    "pino": "^9.0.0",
    "protomux": "^3.6.0",
    "socks": "^2.8.7",
    "sodium-universal": "^4.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@hyperswarm/testnet": "^3.0.0",
    "brittle": "^3.5.0",
    "standard": "^17.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigdestiny2/p2p-hiverelay"
  },
  "keywords": [
    "p2p",
    "relay",
    "hyperswarm",
    "hypercore",
    "pear",
    "holepunch",
    "decentralized",
    "peer-to-peer"
  ]
}
